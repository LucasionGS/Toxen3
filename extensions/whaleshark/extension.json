{
  "id": "whaleshark",
  "name": "Whale Shark Visualizer",
  "version": "1.0.0",
  "author": "Toxen",
  "description": "A whale shark that swims across the screen, reacting to audio frequencies.",
  "main": "index.js",
  "webCompatible": true,
  "visualizers": [
    {
      "id": "whaleshark",
      "name": "Whale Shark",
      "options": [
        {
          "name": "X Position",
          "key": "x",
          "type": "range",
          "defaultValue": -0.1,
          "min": -0.1,
          "max": 100,
          "step": 0.1
        },
        {
          "name": "Y Position",
          "key": "y",
          "type": "range",
          "defaultValue": -0.1,
          "min": -0.1,
          "max": 100,
          "step": 0.1
        },
        {
          "name": "Size",
          "key": "size",
          "type": "range",
          "defaultValue": 0,
          "min": 0,
          "max": 1000,
          "step": 0.1
        },
        {
          "name": "Swimming",
          "key": "swimming",
          "type": "boolean",
          "defaultValue": false
        }
      ]
    }
  ]
}
